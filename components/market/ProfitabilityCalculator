'use client';

import { useState } from 'react';
import { cn, calculateProfitability } from '@/lib/utils';
import { Calculator, TrendingUp, Info } from 'lucide-react';

const exchangeRate = 13450;

export function ProfitabilityCalculator() {
  const [fobPrice, setFobPrice] = useState(50000);
  const [batchQty, setBatchQty] = useState(50000);
  const [regCost, setRegCost] = useState(2000000);

  const calc = calculateProfitability(fobPrice, exchangeRate, 12, 2.5, regCost, batchQty);

  return (
    <div className="rounded-lg border bg-white p-6 shadow-sm">
      <div className="mb-6 flex items-center gap-3">
        <div className="flex h-12 w-12 items-center justify-center rounded-lg bg-emerald-600 text-white">
          <Calculator className="h-6 w-6" />
        </div>
        <div>
          <h3 className="font-semibold text-slate-900">Profitability Calculator</h3>
          <p className="text-sm text-slate-500">Calculate net margins in UZS (Uzbek Som)</p>
        </div>
      </div>

      <div className="mb-6 grid grid-cols-3 gap-4">
        <div>
          <label className="mb-1.5 block text-xs font-medium text-slate-600">Indian FOB Price (INR)</label>
          <input
            type="number"
            value={fobPrice}
            onChange={(e) => setFobPrice(Number(e.target.value))}
            className="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
          />
        </div>
        <div>
          <label className="mb-1.5 block text-xs font-medium text-slate-600">Batch Quantity</label>
          <input
            type="number"
            value={batchQty}
            onChange={(e) => setBatchQty(Number(e.target.value))}
            className="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
          />
        </div>
        <div>
          <label className="mb-1.5 block text-xs font-medium text-slate-600">Registration Cost (INR)</label>
          <input
            type="number"
            value={regCost}
            onChange={(e) => setRegCost(Number(e.target.value))}
            className="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
          />
        </div>
      </div>

      <div className="rounded-lg bg-slate-50 p-4">
        <div className="mb-4 flex items-center justify-between">
          <span className="text-sm text-slate-600">Cost Breakdown</span>
          <span className="text-xs text-slate-500">1 INR = {exchangeRate} UZS</span>
        </div>
        <div className="space-y-2">
          <div className="flex justify-between text-sm">
            <span className="text-slate-500">FOB Price (UZS)</span>
            <span className="font-medium">{calc.fobPriceUZS.toLocaleString()} UZS</span>
          </div>
          <div className="flex justify-between text-sm">
            <span className="text-slate-500">+ Uzbek VAT (12%)</span>
            <span className="font-medium text-amber-600">+{calc.uzbekVat.toLocaleString()} UZS</span>
          </div>
          <div className="flex justify-between text-sm">
            <span className="text-slate-500">+ Logistics (2.5%)</span>
            <span className="font-medium text-amber-600">+{calc.logistics.toLocaleString()} UZS</span>
          </div>
          <div className="flex justify-between text-sm">
            <span className="text-slate-500">+ Registration Amortized</span>
            <span className="font-medium text-amber-600">+{calc.registrationAmortized.toLocaleString()} UZS</span>
          </div>
          <div className="border-t pt-2 mt-2 flex justify-between text-sm font-semibold">
            <span className="text-slate-700">Total Cost (UZS)</span>
            <span className="text-slate-900">{calc.totalCostUZS.toLocaleString()} UZS</span>
          </div>
        </div>
      </div>

      <div className="mt-4 rounded-lg border-2 border-emerald-200 bg-emerald-50 p-4">
        <div className="flex items-center justify-between">
          <div>
            <p className="text-sm text-emerald-700">Suggested Selling Price</p>
            <p className="text-2xl font-bold text-emerald-700">{calc.suggestedSellingPrice.toLocaleString()} UZS</p>
          </div>
          <div className="text-right">
            <div className="flex items-center gap-1 text-emerald-600">
              <TrendingUp className="h-4 w-4" />
              <span className="text-lg font-bold">{calc.marginPercent.toFixed(1)}%</span>
            </div>
            <p className="text-sm text-emerald-600">Net Margin</p>
            <p className="text-xs text-emerald-500">{calc.netMargin.toLocaleString()} UZS</p>
          </div>
        </div>
      </div>

      <div className="mt-4 flex items-start gap-2 rounded-lg bg-blue-50 p-3">
        <Info className="mt-0.5 h-4 w-4 flex-shrink-0 text-blue-600" />
        <p className="text-xs text-blue-700">
          This calculation includes 12% Uzbek VAT, 2.5% logistics costs, and amortized registration fees over the batch quantity.
        </p>
      </div>
    </div>
  );
}
